+        // Prevent duplicate notifications on prompt redraws (e.g. terminal
+        // resize, vi-mode switch).  We store the duration value of the last
+        // notification in a per-session marker file.  If the current duration
+        // matches, the notification has already been shown for this command.
+        // See https://github.com/starship/starship/issues/3291
+        let marker: Option<PathBuf> = context.get_env("STARSHIP_SESSION_KEY").map(|key| {
+            // Prefer XDG_RUNTIME_DIR (tmpfs on systemd systems) to avoid
+            // unnecessary disk writes; fall back to the OS temp directory.
+            let base = context
+                .get_env("XDG_RUNTIME_DIR")
+                .map(PathBuf::from)
+                .unwrap_or_else(std::env::temp_dir);
+            let dir = base.join("starship-notify");
+            let _ = fs::create_dir_all(&dir);
+            dir.join(key)
+        });
+
+        if let Some(ref path) = marker {
+            if let Ok(contents) = fs::read_to_string(path) {
+                if let Ok(prev) = contents.trim().parse::<u128>() {
+                    if prev == elapsed {
+                        return module;
+                    }
+                }
+            }
+        }
