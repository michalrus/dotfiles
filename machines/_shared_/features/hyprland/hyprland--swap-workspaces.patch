+void CCompositor::swapWorkspaces(PHLWORKSPACE pWorkspaceA, PHLWORKSPACE pWorkspaceB) {
+    if (!pWorkspaceA || !pWorkspaceB || pWorkspaceA == pWorkspaceB)
+        return;
+
+    // If the workspaces are on different monitors, fall back to swapActiveWorkspaces
+    // which handles the cross-monitor geometry adjustments.
+    const auto PMONITORA = pWorkspaceA->m_monitor.lock();
+    const auto PMONITORB = pWorkspaceB->m_monitor.lock();
+    if (PMONITORA != PMONITORB) {
+        // swapActiveWorkspaces requires both to be the active workspace on their
+        // respective monitors.  If they aren't, this is not a supported case.
+        if (PMONITORA && PMONITORB && PMONITORA->m_activeWorkspace == pWorkspaceA && PMONITORB->m_activeWorkspace == pWorkspaceB) {
+            swapActiveWorkspaces(PMONITORA, PMONITORB);
+            return;
+        }
+        Debug::log(ERR, "swapWorkspaces: cross-monitor swap requires both workspaces to be active on their monitors");
+        return;
+    }
+
+    const auto PMONITOR = PMONITORA;
+    if (!PMONITOR)
+        return;
+
+    const auto IDA = pWorkspaceA->m_id;
+    const auto IDB = pWorkspaceB->m_id;
+    const auto NAMEA = pWorkspaceA->m_name;
+    const auto NAMEB = pWorkspaceB->m_name;
+
+    Debug::log(LOG, "swapWorkspaces: swapping {} ({}) and {} ({}) on monitor {}", IDA, NAMEA, IDB, NAMEB, PMONITOR->m_id);
+
+    // 1. Swap IDs and names on the workspace objects.
+    pWorkspaceA->m_id   = IDB;
+    pWorkspaceA->m_name = NAMEB;
+    pWorkspaceB->m_id   = IDA;
+    pWorkspaceB->m_name = NAMEA;
+
+    // 2. Update layout node workspace IDs.
+    g_pLayoutManager->getCurrentLayout()->swapWorkspaceIDs(IDA, IDB);
+
+    // 3. Update m_prevWorkspace references across all workspaces.
+    for (auto const& ws : getWorkspaces()) {
+        auto prev = ws->getPrevWorkspaceIDName();
+        if (prev.id == IDA) {
+            ws->rememberPrevWorkspace(pWorkspaceB);
+        } else if (prev.id == IDB) {
+            ws->rememberPrevWorkspace(pWorkspaceA);
+        }
+    }
+
+    // 4. Damage the monitor to ensure a repaint.
+    g_pHyprRenderer->damageMonitor(PMONITOR);
+
+    // 5. Emit IPC events.
+    g_pEventManager->postEvent(SHyprIPCEvent{.event = "renameworkspace", .data = std::format("{},{}", pWorkspaceA->m_id, pWorkspaceA->m_name)});
+    g_pEventManager->postEvent(SHyprIPCEvent{.event = "renameworkspace", .data = std::format("{},{}", pWorkspaceB->m_id, pWorkspaceB->m_name)});
+    pWorkspaceA->m_events.renamed.emit();
+    pWorkspaceB->m_events.renamed.emit();
+}
