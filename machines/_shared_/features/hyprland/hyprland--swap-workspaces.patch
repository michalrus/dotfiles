+SDispatchResult CKeybindManager::swapWorkspaces(std::string args) {
+    const auto FIRST  = args.substr(0, args.find_first_of(' '));
+    const auto SECOND = args.substr(args.find_first_of(' ') + 1);
+
+    const auto& [IDA, NAMEA, AUTOA] = getWorkspaceIDNameFromString(FIRST);
+    const auto& [IDB, NAMEB, AUTOB] = getWorkspaceIDNameFromString(SECOND);
+
+    if (IDA == WORKSPACE_INVALID || IDB == WORKSPACE_INVALID)
+        return {.success = false, .error = "Invalid workspace identifier"};
+
+    if (IDA == IDB)
+        return {};
+
+    auto PWORKSPACEA = g_pCompositor->getWorkspaceByID(IDA);
+    auto PWORKSPACEB = g_pCompositor->getWorkspaceByID(IDB);
+
+    const auto PMONITOR = g_pCompositor->m_lastMonitor.lock();
+    if (!PMONITOR)
+        return {.success = false, .error = "No active monitor"};
+
+    if (!PWORKSPACEA)
+        PWORKSPACEA = g_pCompositor->createNewWorkspace(IDA, PMONITOR->m_id, NAMEA);
+    if (!PWORKSPACEB)
+        PWORKSPACEB = g_pCompositor->createNewWorkspace(IDB, PMONITOR->m_id, NAMEB);
+
+    g_pCompositor->swapWorkspaces(PWORKSPACEA, PWORKSPACEB);
+
+    return {};
+}
